# Database (PostgreSQL - Supabase/Neon/local)
DATABASE_URL=postgresql://user:pass@localhost:5432/journeylog

# Auth.js
# Buat AUTH_SECRET (PowerShell): [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }) -as [byte[]])
AUTH_SECRET="hasil-dari-perintah-di-atas"
AUTH_URL="http://localhost:3000"

# Supabase Storage
# Project URL (BUKAN REST URL): https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
# service_role key (secret, diawali eyJ...) — BUKAN publishable key
SUPABASE_SERVICE_ROLE_KEY="eyJhbG..."
NEXT_PUBLIC_SUPABASE_BUCKET="journeylog-images"
