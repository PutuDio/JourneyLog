generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  createdAt     DateTime  @default(now()) @map("created_at")
  categories    Category[]
  tags          Tag[]
  notes         Note[]
  accounts      Account[]
  sessions      Session[]
  taskLists     TaskList[]
  tasks         Task[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Category {
  id     String @id @default(cuid())
  userId String @map("user_id")
  name   String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes  Note[]

  @@unique([userId, name])
  @@map("categories")
}

model Tag {
  id       String    @id @default(cuid())
  userId   String    @map("user_id")
  name     String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteTags NoteTag[]
  taskTags TaskTag[]

  @@unique([userId, name])
  @@map("tags")
}

model Note {
  id         String      @id @default(cuid())
  userId     String      @map("user_id")
  categoryId String      @map("category_id")
  title      String
  content    String      @db.Text
  isArchived Boolean     @default(false) @map("is_archived")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  noteTags   NoteTag[]
  images     NoteImage[]

  @@index([userId, isArchived, updatedAt])
  @@index([userId, title])
  @@map("notes")
}

model NoteTag {
  noteId String @map("note_id")
  tagId  String @map("tag_id")
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
  @@map("note_tags")
}

model NoteImage {
  id       String @id @default(cuid())
  noteId   String @map("note_id")
  imageUrl String @map("image_url")
  note     Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@map("note_images")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("password_reset_tokens")
}

model TaskList {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  color     String?  // Untuk warna list
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@unique([userId, name])
  @@map("task_lists")
}

model Task {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  listId      String?   @map("list_id")
  title       String
  description String?   @db.Text
  isCompleted Boolean   @default(false) @map("is_completed")
  dueDate     DateTime? @map("due_date")
  startDate   DateTime? @map("start_date") // untuk kalender range/event
  endDate     DateTime? @map("end_date")
  allDay      Boolean   @default(false) @map("all_day")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  list        TaskList? @relation(fields: [listId], references: [id], onDelete: SetNull)
  taskTags    TaskTag[]

  @@index([userId, isCompleted, dueDate])
  @@map("tasks")
}

model TaskTag {
  taskId String @map("task_id")
  tagId  String @map("tag_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@map("task_tags")
}
